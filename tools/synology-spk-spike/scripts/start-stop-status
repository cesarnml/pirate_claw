#!/bin/sh
set -eu

DOCKER_BIN="/usr/local/bin/docker"
CONTAINER_NAME="pirate-claw-spk-spike"
IMAGE_NAME="busybox:latest"
LOG_FILE="/tmp/pirate-claw-spk-spike.log"

log() {
  printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" >>"$LOG_FILE"
}

case "${1:-status}" in
  start)
    log "start requested as user=$(id -un 2>/dev/null || true) uid=$(id -u 2>/dev/null || true) path=$PATH"
    if [ ! -x "$DOCKER_BIN" ]; then
      log "docker binary not executable at $DOCKER_BIN"
      exit 1
    fi

    "$DOCKER_BIN" rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    "$DOCKER_BIN" pull "$IMAGE_NAME" >>"$LOG_FILE" 2>&1
    "$DOCKER_BIN" run -d --name "$CONTAINER_NAME" "$IMAGE_NAME" sleep 1d >>"$LOG_FILE" 2>&1
    log "container started"
    exit 0
    ;;
  stop)
    log "stop requested"
    if [ -x "$DOCKER_BIN" ]; then
      "$DOCKER_BIN" rm -f "$CONTAINER_NAME" >>"$LOG_FILE" 2>&1 || true
    fi
    exit 0
    ;;
  status)
    if [ -x "$DOCKER_BIN" ] && "$DOCKER_BIN" inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null | grep -qx true; then
      exit 0
    fi
    exit 1
    ;;
  log)
    echo "$LOG_FILE"
    exit 0
    ;;
  *)
    log "unsupported action ${1:-}"
    exit 1
    ;;
esac
